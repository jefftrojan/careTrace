# AI Provider: "github" (fast, cloud) or "ollama" (local, private)
AI_PROVIDER=github

# GitHub Models — get token at github.com/settings/tokens (read:models scope)
GITHUB_TOKEN=
GITHUB_MODEL=gpt-4o-mini

# Ollama — used when AI_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b

# FHIR server (Docker HAPI)
HAPI_FHIR_URL=http://localhost:8080/fhir
